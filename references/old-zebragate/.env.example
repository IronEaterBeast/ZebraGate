NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
ZEBRAGATE_DESKTOP_REMOTE_API_BASE_URL=
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3000
ZEBRAGATE_DESKTOP_WEB_BASE_URL=
# Set to "true" only for local development to allow the x-zebragate-user-id
# header (or ZEBRAGATE_MOCK_USER_ID fallback) to authenticate requests when no
# Supabase access token is present. Must be unset/false in production.
ZEBRAGATE_ALLOW_MOCK_AUTH=true
NEXT_PUBLIC_ZEBRAGATE_MOCK_USER_ID=00000000-0000-0000-0000-000000000001
ZEBRAGATE_MOCK_USER_ID=00000000-0000-0000-0000-000000000001
ZEBRAGATE_ADMIN_USERNAME=admin
ZEBRAGATE_ADMIN_PASSWORD=change-me
FREE_DAILY_SITE_BUDGET_CREDITS=500000
FREE_DAILY_USER_LIMIT_CREDITS=5000
DEFAULT_REGISTER_GIFT_CREDITS=500
DEFAULT_DAILY_CHECKIN_CREDITS=20
DEFAULT_LOCAL_PROXY_PORT=7788
# Fastify log level for the API server. Defaults to "warn" to hide per-request
# access logs. Set to "info" or "debug" for more verbose request logging.
LOG_LEVEL=warn
