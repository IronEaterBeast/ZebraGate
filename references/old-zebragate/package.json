{
  "name": "zebragate",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "pretest": "node scripts/verify-root-test-script.cjs",
    "dev:web": "dotenv -e .env -- pnpm --filter @zebragate/web dev",
    "dev:api": "dotenv -e .env -- pnpm --filter @zebragate/api dev",
    "dev:desktop": "dotenv -e .env -- pnpm --filter @zebragate/desktop dev",
    "dev:desktop:webview": "pnpm --filter @zebragate/desktop dev:webview",
    "build:web": "dotenv -e .env -- pnpm --filter @zebragate/web build",
    "build:api": "dotenv -e .env -- pnpm --filter @zebragate/api build",
    "build:desktop": "dotenv -e .env -- pnpm --filter @zebragate/desktop build",
    "build:desktop:webview": "pnpm --filter @zebragate/desktop build:webview",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test:api": "pnpm --filter @zebragate/api test",
    "test:web": "pnpm --filter @zebragate/web test",
    "test:desktop:webview": "pnpm --filter @zebragate/desktop test:webview",
    "test:desktop:rust": "pnpm --filter @zebragate/desktop test:rust",
    "test:desktop": "pnpm --filter @zebragate/desktop test",
    "test": "pnpm test:api && pnpm test:web && pnpm test:desktop"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
