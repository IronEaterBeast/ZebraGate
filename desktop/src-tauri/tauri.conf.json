{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZebraGate",
  "version": "0.1.0",
  "identifier": "dev.zebragate.app",
  "build": {
    "beforeDevCommand": "pnpm run dev:webview",
    "beforeBuildCommand": "pnpm run build:webview",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "ZebraGate",
        "width": 480,
        "height": 320,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
