{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZebraGate",
  "version": "1.0.0",
  "identifier": "dev.zebragate.app",
  "build": {
    "beforeDevCommand": "pnpm run dev:webview",
    "beforeBuildCommand": "pnpm run build:webview",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "ZebraGate",
        "width": 480,
        "height": 320,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://app.example.com/desktop/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDRkFCNDlEREE2QjY2QUQKUldTdFptdmFuYlQ2UEI4SjhmVU5CR0toTzMvY3hHSUJIYmVHYktGdDQ5Y3RyUmMyeTJlT2VrcGYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
