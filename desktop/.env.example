# ZebraGate Desktop 构建期参数（不是给最终用户的运行时配置）
#
# 这些值在「构建」时由 build.rs 读取，通过 Rust 的 option_env!
# 在编译期固化进二进制。最终用户拿到的安装包里不包含这些文件，
# 也无法在运行时修改这些值。
#
# 开发与生产是两套独立、各自固化的配置，由构建 profile 自动选择：
#   - 开发构建（pnpm dev / cargo debug）  -> 读取 desktop/.env.development
#   - 发布构建（pnpm build / cargo release）-> 读取 desktop/.env.production
#
# 使用方式：
#   1. 复制本文件为 desktop/.env.development，填入本地开发地址
#      （如 http://localhost 系列），此后 `pnpm dev` 会自动加载，无需每次手动指定。
#   2. 复制本文件为 desktop/.env.production，填入正式环境真实地址，
#      供 `pnpm build`（tauri build）使用。
#   3. 两个文件名都会被 .gitignore 忽略，不入库。
#
# 备注：若对应文件不存在，会退回到运行时环境变量（同名变量），仅供临时调试。
# 注意：本文件仅作模板，请勿在此填写真实正式地址。

# 远端后端 API 地址（原厂固定，用户不可改）
ZEBRAGATE_DESKTOP_REMOTE_API_BASE_URL=https://api.example.com

# 远端 Web 页面地址（登录等内嵌页面使用）
ZEBRAGATE_DESKTOP_WEB_BASE_URL=https://app.example.com
